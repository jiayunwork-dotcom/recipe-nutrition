{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:scope-home",
    "fs:scope-home-recursive",
    "fs:scope-desktop",
    "fs:scope-desktop-recursive",
    "fs:scope-document",
    "fs:scope-document-recursive",
    "fs:scope-download",
    "fs:scope-download-recursive",
    "fs:scope-picture",
    "fs:scope-picture-recursive",
    "fs:scope-public",
    "fs:scope-public-recursive",
    "fs:scope-temp",
    "fs:scope-temp-recursive",
    "fs:scope-runtime",
    "fs:scope-runtime-recursive",
    "fs:scope-app",
    "fs:scope-app-recursive",
    "fs:scope-appdata",
    "fs:scope-appdata-recursive",
    "fs:scope-appconfig",
    "fs:scope-appconfig-recursive",
    "fs:scope-applocaldata",
    "fs:scope-applocaldata-recursive",
    "fs:scope-cache",
    "fs:scope-cache-recursive",
    "fs:scope-log",
    "fs:scope-log-recursive",
    "shell:default",
    "shell:allow-open"
  ]
}
